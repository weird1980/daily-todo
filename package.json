{
  "name": "daily-todo",
  "version": "1.0.0",
  "description": "A local-first daily task manager: REST + WebSocket server, React dashboard, and CLI. Multi-language (en/es/ca/fr).",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weird1980/daily-todo.git"
  },
  "homepage": "https://github.com/weird1980/daily-todo#readme",
  "bugs": {
    "url": "https://github.com/weird1980/daily-todo/issues"
  },
  "workspaces": [
    "server",
    "dashboard",
    "cli"
  ],
  "scripts": {
    "dev": "concurrently -n server,dashboard -c blue,green \"npm run start -w server\" \"npm run dev -w dashboard\"",
    "start": "npm run dev",
    "server": "npm run start -w server",
    "dashboard": "npm run dev -w dashboard",
    "build": "npm run build -w dashboard",
    "test": "npm run test -w server"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
